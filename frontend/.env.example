# Sentinel Frontend Environment Variables
#
# EXPO_PUBLIC_BACKEND_URL: Base URL of the deployed FastAPI backend.
# IMPORTANT:
# - Must include "https://" (e.g. https://your-backend.example.com)
# - Must NOT end in "/api" (the frontend appends "/api" internally)
# - Must NOT end with a trailing slash "/"
#
EXPO_PUBLIC_BACKEND_URL=https://your-backend.example.com

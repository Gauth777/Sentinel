# FastAPI Port Configuration
PORT=8000

# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=test_database

# Neo4j Perception Graph Configuration
# Recommended deployed demo settings:
NEO4J_ENABLED=true
SENTINEL_NEO4J_STRICT=true
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DATABASE=neo4j

# Demo Scenario Asset Directory
SENTINEL_DEMO_SCENARIO_DIR=demo_scenarios

# Qwen Multimodal VLM Configuration
# Recommended deployed demo settings:
SENTINEL_QWEN_ENABLED=false
SENTINEL_QWEN_BASE_URL=https://api.openai.com/v1
SENTINEL_QWEN_API_KEY=your_api_key_here
SENTINEL_QWEN_MODEL=Qwen2.5-VL-7B-Instruct
SENTINEL_QWEN_TIMEOUT_SECONDS=30
SENTINEL_QWEN_PROMPT_VERSION=v1

# CORS Origins Hardening Configuration
# Comma-separated list of allowed origins. Unset/empty permits wildcard "*" (with credentials disabled).
CORS_ORIGINS=https://sentinel.example.com,https://gv.example.com
